{
  "name": "@agentdbg/opencode",
  "version": "0.1.1",
  "description": "AgentDbg plugin for OpenCode — records OpenCode sessions as AgentDbg traces.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "agentdbg",
    "opencode",
    "tracing",
    "debugging",
    "ai-agents",
    "observability"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@agentdbg/core": "^0.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.3",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
